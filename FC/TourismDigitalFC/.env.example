# ============================================================
# Railway Environment Variables Template
# Copy these variable names into the Railway dashboard
# and fill in your real values (never commit real keys!)
# ============================================================

# MongoDB Atlas (Cloud)
USE_LOCAL_MONGODB=false
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=sigiriya_tourism

# JWT Secret for admin authentication
SECRET_KEY=replace_with_your_strong_secret_key

# OpenWeatherMap API
OPENWEATHER_API_KEY=replace_with_your_openweather_api_key

# Google Gemini API
GEMINI_API_KEY=replace_with_your_gemini_api_key
